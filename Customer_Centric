<input id="msg">
<button onclick="send()">Enviar</button>

<script>

const WEBHOOK=https://kukulcanai.app.n8n.cloud/webhook/816a475f-26e4-4deb-adcc-9458bbd65268

async function send(){

const text=document.getElementById("msg").value

const r=await fetch(WEBHOOK,{
method:"POST",
headers:{"Content-Type":"application/json"},
body:JSON.stringify({
sessionId:"demo1",
message:text,
history:[]
})
})

const data=await r.json()

alert(data.assistantMessage)

}

</script>
